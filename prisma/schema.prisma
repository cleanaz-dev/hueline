// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../app/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model SubdomainUser {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String?
  passwordHash String
  imageUrl     String?
  role         UserRole @default(MEMBER)
  phone        String?

  subdomainId String
  subdomain   Subdomain @relation(fields: [subdomainId], references: [id])
  rooms       Room[]

  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  clientCommunications ClientCommunication[]
  systemTasks          SystemTask[]
  designProjects       DesignProject[]
}

enum UserRole {
  MEMBER
  ADMIN
  OWNER
  SUPER_ADMIN
}

model DesignProject {
  id   String  @id @default(uuid())
  name String? @default("Untitled Design")

  // The Base Canvas
  originalImageS3Key   String?
  compressedImageS3Key String?

  // Active Settings (Saves their progress)
  activeBrand     String?
  activeColorCode String?
  activeColorHex  String?
  removeFurniture Boolean @default(false)

  // Relations: Who owns this?
  subdomainId String
  subdomain   Subdomain @relation(fields: [subdomainId], references: [id], onDelete: Cascade)

  creatorId String?
  creator   SubdomainUser? @relation(fields: [creatorId], references: [id])

  // The "Connect Booking" Feature
  bookingId String?
  booking   SubBookingData? @relation(fields: [bookingId], references: [id])

  // Connect Customer
  customerId String?
  customer   Customer? @relation(fields: [customerId], references: [id])

  // The generated images (reusing your existing Mockup model)
  mockups Mockup[]

  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  mediaAssets MediaAsset[]

  @@index([subdomainId])
  @@index([bookingId])
}

model Client {
  id        String  @id @default(uuid())
  email     String  @unique
  firstName String?
  lastName  String?
  country   String?
  city      String?
  state     String?

  status ClientStatus @default(PENDING_INTAKE)

  // Stripe Data
  stripeCustomerId     String?   @unique
  stripeSubscriptionId String?
  setupFeePaid         Boolean   @default(false)
  planStatus           String    @default("active")
  currentPeriodEnd     DateTime?
  planPrice            String?
  planName             String?

  // company info
  company String?
  phone   String?
  hours   String?
  crm     String?

  // subdomain info
  subdomain            Subdomain?
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  formData             FormData?
  clientActivities     ClientActivity[]
  clientCommunications ClientCommunication[]
}

model SubSettings {
  id          String     @id @default(uuid())
  subdomain   Subdomain? @relation(fields: [subdomainId], references: [id])
  subdomainId String?    @unique
  features    String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model FormData {
  id       String   @id @default(uuid())
  email    String   @unique
  company  String?
  phone    String?
  country  String?
  city     String?
  state    String?
  features String[]
  config   Json?
  hours    String?
  name     String?
  crm      String?

  subdomainId String?    @unique
  subdomain   Subdomain? @relation(fields: [subdomainId], references: [id])
  client      Client?    @relation(fields: [clientId], references: [id])
  clientId    String?    @unique
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum ClientStatus {
  PENDING_INTAKE
  INTAKE_FORM_COMPLETE
  SETUP_LINK_SENT
  FEE_PAID
  WORK_COMPLETED
  DEMO_APPROVED
  JOB_COMPLETED
}

enum ClientActivityType {
  // Onboarding & Intake
  CLIENT_CREATED
  INTAKE_LINK_SENT
  INTAKE_FORM_STARTED
  INTAKE_FORM_COMPLETED
  CLIENT_INFO_UPDATED
  MEETING_BOOKED

  // Billing & Stripe
  SETUP_LINK_SENT
  SETUP_FEE_PAID
  SUBSCRIPTION_STARTED
  SUBSCRIPTION_UPDATED
  PAYMENT_FAILED
  SUBSCRIPTION_CANCELED

  // Fulfillment & Lifecycle
  WORK_STARTED
  WORK_COMPLETED
  DEMO_SENT
  DEMO_APPROVED
  JOB_COMPLETED

  // System & Tech
  SUBDOMAIN_PROVISIONED
  INTEGRATION_CONNECTED
  EMAIL_SENT
  SMS_SENT

  //Client Portal & IMAGES
  GENERATED_IMAGE
  SHARED_PROJECT
  UPSCALED_IMAGE
  FOLLOWUP_IMAGE_SENT
  INBOUND_CALL
  OUTBOUND_CALL
  INBOUND_EMAIL
  VOICE_OUTBOUND
  VOICE_INBOUND
  SMS_INBOUND
  QUOTE_GENERATION
  AI_PAUSED
}

model ChatThread {
  id      String @id @default(uuid())
  shortId String @unique

  customerId String
  customer   Customer @relation(fields: [customerId], references: [id])

  subdomain   Subdomain @relation(fields: [subdomainId], references: [id])
  subdomainId String

  status String  @default("OPEN") // "OPEN", "SNOOZED", "CLOSED"
  title  String? // e.g. "Website Inquiry" or "Exterior Painting 2026"

  isAutoPilot Boolean @default(false)

  // The Messages
  activities     ClientActivity[]
  communications ClientCommunication[]

  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt // Push to top of UI when new message arrives
  bookingData       SubBookingData[]
  followUpSchedules FollowUpSchedule[]
  calls             Call[]
  mediaAssets       MediaAsset[]
  errorLogs         ErrorLog[]
}

model ClientActivity {
  id   String             @id @default(uuid())
  type ClientActivityType

  // A short, human-readable summary (e.g., "Paid $500 Setup Fee" or "Intake Form Completed")
  title String?

  // Longer description or automated system notes (e.g., "Stripe payment succeeded. SubId: sub_123")
  description String?

  // Store dynamic data like Stripe Session IDs, email payloads, or previous state values
  metadata Json?

  // Relations
  client   Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientId String?

  subDomain    Subdomain?  @relation(fields: [subDomainId], references: [id], onDelete: Cascade)
  subDomainId  String?
  // Timeline stamps
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  customer     Customer?   @relation(fields: [customerId], references: [id])
  customerId   String?
  chatThread   ChatThread? @relation(fields: [chatThreadId], references: [id])
  chatThreadId String?
}

model Subdomain {
  id                 String            @id @default(uuid())
  slug               String            @unique
  domain             String?
  companyName        String?
  active             Boolean           @default(true)
  intelligenceId     String?
  intelligence       Intelligence?     @relation(fields: [intelligenceId], references: [id])
  roomIntelligenceId String?
  roomIntelligence   RoomIntelligence? @relation(fields: [roomIntelligenceId], references: [id])

  twilioPhoneNumber String?
  forwardingNumber  String?
  branding          Branding?
  subSettings       SubSettings?
  FormData          FormData?
  bookings          SubBookingData[]
  users             SubdomainUser[]
  logs              Logs[]
  calls             Call[]
  // Call Flow Relations
  callFlows         CallFlow[] // Contains the history (versions)
  activeFlowId      String?
  rooms             Room[]
  client            Client?          @relation(fields: [clientId], references: [id])
  clientId          String?          @unique

  clientActivities  ClientActivity[]
  customers         Customer[]
  systemTasks       SystemTask[]
  designProjects    DesignProject[]
  errorLogs         ErrorLog[]
  chatThreads       ChatThread[]
  quotes            Quote[]
  followUpSchedules FollowUpSchedule[]
  mediaAssets       MediaAsset[]

  createdAt DateTime  @default(now())
  updatedAt DateTime? @updatedAt
}

model FollowUpSchedule {
  id           String         @id @default(uuid())
  title        String?
  triggerAt    DateTime
  reason       String // e.g., "Customer said they are busy, checking back tomorrow"
  status       FollowUpStatus @default(PENDING) // PENDING, COMPLETED, CANCELLED
  scheduleName String?

  // Relations
  chatThreadId String
  chatThread   ChatThread @relation(fields: [chatThreadId], references: [id])
  customerId   String
  customer     Customer   @relation(fields: [customerId], references: [id])
  subdomainId  String
  subdomain    Subdomain  @relation(fields: [subdomainId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum FollowUpStatus {
  PENDING
  COMPLETED
  CANCELLED
}

model Branding {
  id             String  @id @default(uuid())
  logoUrl        String?
  logoWidth      Int?    @default(130)
  logoHeight     Int?    @default(130)
  splashScreen   String?
  primaryColor   String?
  secondaryColor String?
  theme          String?

  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  subdomain   Subdomain @relation(fields: [subdomainId], references: [id], onDelete: Cascade)
  subdomainId String    @unique
}

model RoomIntelligence {
  id String @id @default(uuid())

  prompt       String?
  intelligence Json?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  Subdomain    Subdomain[]
}

model Intelligence {
  id        String    @id @default(uuid())
  prompt    String?
  values    Json?
  schema    Json?
  createdAt DateTime? @default(now())
  updatedAt DateTime? @updatedAt

  subdomain Subdomain[]
}

model CallFlow {
  id String @id @default(uuid())

  subdomain   Subdomain @relation(fields: [subdomainId], references: [id], onDelete: Cascade)
  subdomainId String

  version Int // e.g. 1, 2, 3
  nodes   Json // <--- THIS SAVES US (Stores the entire FlowNode object)

  isPublished Boolean  @default(false)
  createdAt   DateTime @default(now())

  @@index([subdomainId])
}

model SubBookingData {
  id          String         @id @default(uuid())
  subdomainId String
  subdomain   Subdomain      @relation(fields: [subdomainId], references: [id], onDelete: Cascade)
  huelineId   String         @unique
  status      BookingStatus? @default(PENDING)

  // ... Client Details ...
  name                   String
  phone                  String
  roomType               String
  prompt                 String
  originalImages         String
  compressOriginalImages String?
  summary                String
  dimensions             String?
  dateTime               DateTime?
  pin                    String
  guestPins              String[]
  expiresAt              Int?

  // ... The "Perfect Sauce" Logic ...

  // 1. GENESIS (Immutable)
  initialIntent CallReason @default(NEW_PROJECT)

  // 2. SNAPSHOT (Overwritten every call)
  lastCallReason      CallReason?
  lastCallAt          DateTime?
  lastCallAudioUrl    String?
  lastVideoUrl        String?
  lastVideoAt         String?
  lastInteraction     String? // The new "Pulse" headline
  selfServeCompletion Boolean?    @default(false)

  // 3. STICKY / ACCUMULATIVE (Builds up over time)
  projectType    String? // e.g. "Residential"
  projectScope   String[] // ✅ Renamed & Array (e.g. ["Interior", "Cabinets"])
  estimatedValue Float? // Cumulative math

  // ... Relations ...
  mockups      Mockup[]
  paintColors  PaintColor[]
  sharedAccess SharedAccess[]
  exports      Export[]
  calls        Call[]
  logs         Logs[]
  rooms        Room[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  customer        Customer?       @relation(fields: [customerId], references: [id])
  customerId      String?
  designProjects  DesignProject[]
  quotes          Quote[]
  relatedThreadId String?
  relatedThread   ChatThread?     @relation(fields: [relatedThreadId], references: [id])
  mediaAssets     MediaAsset[]
}

model Quote {
  id          String          @id @default(uuid())
  customer    Customer?       @relation(fields: [customerId], references: [id])
  customerId  String?
  booking     SubBookingData? @relation(fields: [bookingId], references: [id])
  bookingId   String?
  subdomain   Subdomain       @relation(fields: [subdomainId], references: [id])
  subdomainId String
  huelineId   String?
  version     Int             @default(1)
  status      QuoteStatus     @default(DRAFT)
  items       Json?           @db.Json
  totalAmount Float?          @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum QuoteStatus {
  DRAFT
  READY
  SENT
  ACCEPTED
}

model Customer {
  id              String        @id @default(uuid())
  name            String?
  phone           String?
  email           String?
  initialFollowUp Boolean?      @default(false)
  status          BookingStatus @default(PENDING)

  subdomain      Subdomain?       @relation(fields: [subdomainId], references: [id])
  subdomainId    String?
  subBookingData SubBookingData[]

  communication ClientCommunication[]

  createdAt         DateTime?          @default(now())
  updatedAt         DateTime?          @updatedAt
  clientActivities  ClientActivity[]
  systemTasks       SystemTask[]
  customerType      CustomerType       @default(RESIDENTIAL)
  calls             Call[]
  designProjects    DesignProject[]
  errorLogs         ErrorLog[]
  chatThreads       ChatThread[]
  quotes            Quote[]
  followUpSchedules FollowUpSchedule[]
  mediaAssets       MediaAsset[]
}

model MediaAsset {
  id            String             @id @default(uuid())
  fileName      String
  fileType      MediaAssetFileType
  s3Key         String?
  compressedKey String?
  metadata      Json?
  customer      Customer?          @relation(fields: [customerId], references: [id])
  customerId    String?
  thread        ChatThread?        @relation(fields: [threadId], references: [id])
  threadId      String?
  subdomain     Subdomain          @relation(fields: [subdomainId], references: [id])
  subdomainId   String
  booking       SubBookingData?    @relation(fields: [bookingId], references: [id])
  bookingId     String?
  designProject DesignProject?     @relation(fields: [projectId], references: [id])
  projectId     String?

  updatedAt DateTime @updatedAt
  createdAt DateTime @default(now())
}

enum MediaAssetFileType {
  IMAGE
  PDF
}

enum CustomerType {
  RESIDENTIAL // Homeowners
  COMMERCIAL // Businesses, Warehouses
  PROPERTY_MANAGER // Apartment complexes, HOAs
  DEMO
  OTHER
}

model ClientCommunication {
  id               String            @id @default(uuid())
  body             String
  subject          String?
  role             CommunicationRole
  type             CommunicationType
  clientId         String?
  client           Client?           @relation(fields: [clientId], references: [id])
  createdAt        DateTime          @default(now())
  mediaAttachments MediaAttachment[]
  metadata         Json?
  operator         SubdomainUser?    @relation(fields: [operatorId], references: [id])
  operatorId       String?
  customer         Customer?         @relation(fields: [customerId], references: [id])
  customerId       String?
  chatThread       ChatThread?       @relation(fields: [chatThreadId], references: [id])
  chatThreadId     String?
}

model SystemTask {
  id     String           @id @default(uuid())
  status SystemTaskStatus

  type    SystemTaskType // <-- We will use this in our Switch statement!
  model   String?
  cost    Float?
  lockKey String

  initiator      SystemTaskRole
  operator       SubdomainUser? @relation(fields: [operatorId], references: [id])
  operatorId     String?
  deliveryMethod String

  metadata       Json?
  metadataSource MetadataSource?

  // 🌟 NEW: Let the Job know exactly who it is for!
  subdomain   Subdomain @relation(fields: [subdomainId], references: [id])
  subdomainId String

  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  customer   Customer? @relation(fields: [customerId], references: [id])
  customerId String?
  calls      Call[]
}

enum MetadataSource {
  IMAGEN
  UPSCALE
  VOICE
  QUOTE_GENERATION
  COMMUNICATION
  NUDGE
}

enum SystemTaskType {
  IMAGEN
  UPSCALE
  VIDEO
  VOICE_MOCKUP
  VOICE
  STUDIO_IMAGEN
  STUDIO_UPSCALE
  QUOTE_GENERATION
  COMMUNICATION
  NUDGE
  INTELLIGENCE
  OUTBOUND_CALL
  AUDIO
}

model MediaAttachment {
  id                    String              @id @default(uuid())
  filename              String
  mimeType              String
  size                  Int
  mediaSource           MediaSource
  mediaUrl              String
  compressedKey         String?
  zohoAttachmentId      String?
  clientCommunicationId String
  clientCommunication   ClientCommunication @relation(fields: [clientCommunicationId], references: [id])
  createdAt             DateTime            @default(now())
}

enum MediaSource {
  S3
  EXTERNAL
}

enum SystemTaskRole {
  AI
  CLIENT
  USER
  OPERATOR
  SYSTEM
  HUECLAW
}

enum SystemTaskStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CommunicationRole {
  AI
  CLIENT
  USER
  OPERATOR
}

enum CommunicationType {
  SMS
  PHONE
  MEETING
  DEMO
  EMAIL
  IMAGEN
  AI_SUGESSTION
  QUOTE
  NONE
  VOICE
}

enum BookingStatus {
  PENDING
  CLOSED
  LOST
  BOOKED
  WON
}

model Room {
  id          String         @id @default(uuid())
  roomKey     String         @unique
  clientName  String?
  clientPhone String?
  status      RoomStatus     @default(ACTIVE)
  creatorId   String?
  creator     SubdomainUser? @relation(fields: [creatorId], references: [id], onDelete: Cascade)

  booking   SubBookingData? @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  bookingId String?
  domainId  String
  domain    Subdomain       @relation(fields: [domainId], references: [id], onDelete: Cascade)

  scopeData    Json?
  endedAt      DateTime?
  recordingUrl String?
  transcript   String?

  sessionType     RoomType? @default(QUICK)
  agentDispatched Boolean?  @default(false)
  isProcessing    Boolean?  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum RoomType {
  QUICK
  PROJECT
  SELF_SERVE
}

enum RoomStatus {
  ACTIVE
  COMPLETED
  EXPIRED
}

model Call {
  id            String          @id @default(uuid())
  bookingDataId String?
  bookingData   SubBookingData? @relation(fields: [bookingDataId], references: [id], onDelete: Cascade)

  callerName    String?
  callerPhone   String?
  callDirection CallDirection @default(INBOUND)

  callSid      String? @unique
  recordingSid String?
  audioS3Key   String?
  duration     String?
  status       String?
  roomName     String? @unique
  callType     String?

  transcript Json? // <- New!

  intelligence CallIntelligence?

  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  subdomain    Subdomain?  @relation(fields: [subdomainId], references: [id])
  subdomainId  String?
  customer     Customer?   @relation(fields: [customerId], references: [id])
  customerId   String?
  thread       ChatThread? @relation(fields: [threadId], references: [id])
  threadId     String?
  task         SystemTask? @relation(fields: [systemTaskId], references: [id])
  systemTaskId String?

  @@index([bookingDataId])
}

enum CallDirection {
  INBOUND
  OUTBOUND
}

model CallIntelligence {
  id                       String       @id @default(uuid())
  callId                   String       @unique
  call                     Call         @relation(fields: [callId], references: [id], onDelete: Cascade)
  callReason               CallReason   @default(OTHER)
  projectScope             String? // INTERIOR, EXTERIOR, etc. (varies by industry)
  callOutcome              CallOutcome? // POSITIVE, NEUTRAL, NEGATIVE
  estimatedAdditionalValue Float        @default(0)
  customFields             Json?
  costBreakdown            String?

  // METADATA
  transcriptText String?
  callSummary    String? // AI-generated summary

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([callReason])
  @@index([callOutcome])
}

model Export {
  id           String         @id @default(uuid())
  systemTaskId String?        @unique
  bookingId    String
  booking      SubBookingData @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  resolution   String
  imageCount   Int
  status       String
  downloadUrl  String?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  completedAt  DateTime?

  @@index([bookingId])
}

model Mockup {
  id            String         @id @default(uuid())
  bookingDataId String
  bookingData   SubBookingData @relation(fields: [bookingDataId], references: [id], onDelete: Cascade)

  s3Key           String
  compressedS3Key String?
  roomType        String
  presignedUrl    String?

  // --- NEW FIELDS ---
  colorBrand String? // Made optional temporarily for migration
  colorCode  String? // Made optional temporarily for migration
  colorName  String?
  colorHex   String?

  brand String
  code  String
  name  String
  hex   String

  // --- OLD FIELDS (To be deleted after step 2) ---
  colorRal String?

  createdAt       DateTime       @default(now())
  designProject   DesignProject? @relation(fields: [designProjectId], references: [id])
  designProjectId String?

  @@index([bookingDataId])
}

model PaintColor {
  id            String         @id @default(uuid())
  bookingDataId String
  bookingData   SubBookingData @relation(fields: [bookingDataId], references: [id], onDelete: Cascade)

  // --- NEW FIELDS ---
  brand String // Optional temporarily
  code  String // Optional temporarily
  name  String
  hex   String

  // --- OLD FIELDS ---
  ral String?

  createdAt DateTime @default(now())

  @@index([bookingDataId])
}

// 🚨 DON'T FORGET: You have AlternateColor in your SubBookingData model! 
// It probably needs this exact same update.

model SharedAccess {
  id            String         @id @default(uuid())
  bookingDataId String
  bookingData   SubBookingData @relation(fields: [bookingDataId], references: [id], onDelete: Cascade)

  email      String?
  accessType AccessType @default(READ_ONLY)
  pin        String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  @@index([bookingDataId])
}

enum AccessType {
  OWNER
  READ_ONLY
}

enum CallReason {
  NEW_PROJECT
  STATUS_UPDATE
  COLOR_CHANGE
  PRICING
  FOLLOW_UP
  OTHER
}

model Logs {
  id String @id @default(uuid())

  // Relations
  bookingDataId String?
  bookingData   SubBookingData? @relation(fields: [bookingDataId], references: [id], onDelete: Cascade)

  // Keep SubdomainID for fast filtering at the account level
  subdomainId String
  subdomain   Subdomain @relation(fields: [subdomainId], references: [id], onDelete: Cascade)

  type  LogType
  actor LogActor @default(SYSTEM)

  title       String // e.g. "New Call", "Status Update"
  description String? // e.g. "Client asked about pricing"

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([bookingDataId])
  @@index([subdomainId])
}

enum LogType {
  CALL
  MOCKUP
  PAYMENT
  STATUS_CHANGE
  SMS
  NOTE
  SHARE
  ROOM
  UPSCALE
  VIDEO
  MEETING
  QUOTE
  EMAIL
}

enum LogActor {
  AI // The Voice Agent / Gemini
  SYSTEM // Automated tasks (e.g. scheduled reminders)
  PAINTER // The Admin User
  CLIENT // The Homeowner
}

enum CallOutcome {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

model ErrorLog {
  id       String  @id @default(uuid())
  source   String // "imagen-lambda", "voice-ai", etc
  stage    String // "PREDICTION", "S3", "WEBHOOK"
  error    String
  resolved Boolean @default(false)

  // Context
  systemTaskId String?
  huelineId    String?
  messageId    String?

  // Relations
  customer    Customer?   @relation(fields: [customerId], references: [id])
  customerId  String?
  subdomain   Subdomain?  @relation(fields: [subdomainId], references: [id])
  subdomainId String?
  thread      ChatThread? @relation(fields: [threadId], references: [id])
  threadId    String?

  createdAt DateTime @default(now())
}
